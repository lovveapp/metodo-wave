---
import TrainingChart from './TrainingChart.tsx';
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden">
  <!-- Background dot grid -->
  <div
    class="absolute inset-0 opacity-[0.035]"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- Glow blob -->
  <div
    class="absolute pointer-events-none"
    style="top: 30%; left: 50%; transform: translate(-50%, -50%); width: 700px; height: 300px; background: radial-gradient(ellipse at center, rgba(6,182,212,0.10) 0%, transparent 70%); border-radius: 50%;"
  ></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 py-20 flex flex-col items-center text-center gap-8 w-full">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full font-mono text-xs tracking-widest uppercase"
      style="border: 1px solid var(--accent-border); background: var(--accent-dim); color: var(--accent);"
    >
      <span
        class="w-1.5 h-1.5 rounded-full animate-pulse"
        style="background: var(--accent);"
      ></span>
      Método de Estruturação
    </div>

    <!-- Heading -->
    <h1 class="font-mono font-bold text-7xl md:text-9xl tracking-tight text-white leading-none">
      Wave<span style="color: var(--accent);">.</span>
    </h1>

    <p class="font-sans text-lg md:text-xl max-w-2xl leading-relaxed" style="color: var(--muted);">
      Um modelo matemático de estruturação e divisão de treino de força —
      criado a partir das diretrizes do ACSM e fundamentado em evidências científicas.
    </p>

    <!-- CTA -->
    <a
      href="#what-is-wave"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-mono text-sm transition-all duration-200"
      style="background: var(--accent-dim); border: 1px solid var(--accent-border); color: var(--accent);"
    >
      Explorar o método
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path
          d="M8 3l5 5-5 5M3 8h10"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>

    <!-- Training Chart -->
    <div class="w-full mt-4 text-left">
      <TrainingChart client:load />
    </div>
  </div>
</section>

<style>
  .scroll-wrap::-webkit-scrollbar {
    height: 5px;
  }
  .scroll-wrap::-webkit-scrollbar-track {
    background: #18181b;
    border-radius: 3px;
  }
  .scroll-wrap::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 3px;
  }
</style>
