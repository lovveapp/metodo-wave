---
// Wave chart data — computed server-side
const W = 760;
const H = 190;
const padL = 48;
const padR = 20;
const padT = 16;
const padB = 38;
const cW = W - padL - padR;
const cH = H - padT - padB;
const N = 200;

interface Point {
  x: number;
  intensity: number;
  volume: number;
}

const pts: Point[] = Array.from({ length: N }, (_, i) => {
  const t = i / (N - 1);
  const x = padL + t * cW;
  // Intensity: upward trend with sinusoidal undulation (the "wave")
  const iPct = 0.40 + 0.28 * t + 0.16 * Math.sin(t * Math.PI * 6 - 0.8);
  // Volume: inverse relationship
  const vPct = 0.72 - 0.20 * t + 0.14 * Math.sin(t * Math.PI * 6 - 0.8 + Math.PI);
  return {
    x,
    intensity: padT + cH * (1 - Math.min(1, Math.max(0.05, iPct))),
    volume: padT + cH * (1 - Math.min(1, Math.max(0.05, vPct))),
  };
});

const iPath = pts.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.intensity.toFixed(1)}`).join(' ');
const vPath = pts.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.volume.toFixed(1)}`).join(' ');

const weeks = 12;
const wLabels = Array.from({ length: weeks + 1 }, (_, i) => ({
  x: padL + (i / weeks) * cW,
  label: i > 0 ? `S${i}` : '',
}));

const yLabels = [
  { y: padT, label: '100%' },
  { y: padT + cH * 0.33, label: '67%' },
  { y: padT + cH * 0.66, label: '33%' },
];
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden">
  <!-- Background dot grid -->
  <div
    class="absolute inset-0 opacity-[0.035]"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- Glow blob -->
  <div
    class="absolute pointer-events-none"
    style="top: 30%; left: 50%; transform: translate(-50%, -50%); width: 700px; height: 300px; background: radial-gradient(ellipse at center, rgba(6,182,212,0.12) 0%, transparent 70%); border-radius: 50%;"
  ></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 py-20 flex flex-col items-center text-center gap-8">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full font-mono text-xs tracking-widest uppercase"
      style="border: 1px solid var(--accent-border); background: var(--accent-dim); color: var(--accent);"
    >
      <span
        class="w-1.5 h-1.5 rounded-full animate-pulse"
        style="background: var(--accent);"
      ></span>
      Método de Periodização
    </div>

    <!-- Heading -->
    <h1 class="font-mono font-bold text-7xl md:text-9xl tracking-tight text-white leading-none">
      Wave<span style="color: var(--accent);">.</span>
    </h1>

    <!-- Tagline — TODO: substituir pelo texto real -->
    <p class="font-sans text-lg md:text-xl max-w-2xl leading-relaxed" style="color: var(--muted);">
      Periodização inteligente baseada em algoritmos e nas evidências mais atuais
      da ciência do treinamento de força.
    </p>

    <!-- CTA -->
    <a
      href="#what-is-wave"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-mono text-sm transition-all duration-200"
      style="background: var(--accent-dim); border: 1px solid var(--accent-border); color: var(--accent);"
      onmouseover="this.style.background='rgba(6,182,212,0.2)'"
      onmouseout="this.style.background='var(--accent-dim)'"
    >
      Explorar o método
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path
          d="M8 3l5 5-5 5M3 8h10"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>

    <!-- Wave Chart -->
    <div
      class="w-full mt-4 rounded-xl overflow-hidden"
      style="border: 1px solid var(--border); background: rgba(24,24,27,0.6); backdrop-filter: blur(8px);"
    >
      <!-- Chart header -->
      <div
        class="flex items-center gap-3 px-5 py-3"
        style="border-bottom: 1px solid var(--border);"
      >
        <span class="font-mono text-xs tracking-widest uppercase" style="color: var(--subtle);">
          Progressão · 12 semanas
        </span>
        <div class="flex items-center gap-4 ml-auto">
          <span class="flex items-center gap-1.5 font-mono text-xs" style="color: #06b6d4;">
            <span class="inline-block w-5 h-px" style="background: #06b6d4;"></span>
            Intensidade
          </span>
          <span class="flex items-center gap-1.5 font-mono text-xs" style="color: #818cf8;">
            <span class="inline-block w-5 h-px" style="background: #818cf8;"></span>
            Volume
          </span>
        </div>
      </div>

      <!-- SVG chart -->
      <div class="px-2 py-3">
        <svg
          viewBox={`0 0 ${W} ${H}`}
          xmlns="http://www.w3.org/2000/svg"
          class="w-full"
          preserveAspectRatio="xMidYMid meet"
        >
          <defs>
            <filter id="glow-c">
              <feGaussianBlur stdDeviation="2.5" result="blur" />
              <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
            </filter>
            <filter id="glow-v">
              <feGaussianBlur stdDeviation="2.5" result="blur" />
              <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
            </filter>
          </defs>

          <!-- Horizontal grid -->
          {yLabels.map(({ y }) => (
            <line x1={padL} y1={y} x2={W - padR} y2={y} stroke="#27272a" stroke-width="1" />
          ))}
          <!-- Vertical grid (weekly) -->
          {wLabels.map(({ x }) => (
            <line x1={x} y1={padT} x2={x} y2={H - padB} stroke="#27272a" stroke-width="1" />
          ))}

          <!-- Y labels -->
          {yLabels.map(({ y, label }) => (
            <text
              x={padL - 8}
              y={y + 4}
              fill="#52525b"
              font-size="9"
              text-anchor="end"
              font-family="JetBrains Mono, monospace"
            >
              {label}
            </text>
          ))}
          <!-- X labels -->
          {wLabels.filter((w) => w.label).map(({ x, label }) => (
            <text
              x={x}
              y={H - padB + 14}
              fill="#52525b"
              font-size="9"
              text-anchor="middle"
              font-family="JetBrains Mono, monospace"
            >
              {label}
            </text>
          ))}
          <text
            x={(padL + W - padR) / 2}
            y={H - 3}
            fill="#3f3f46"
            font-size="8"
            text-anchor="middle"
            font-family="JetBrains Mono, monospace"
          >
            semanas
          </text>

          <!-- Volume path -->
          <path d={vPath} fill="none" stroke="#818cf8" stroke-width="2.5" stroke-linecap="round" opacity="0.25" filter="url(#glow-v)" />
          <path d={vPath} fill="none" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />

          <!-- Intensity path -->
          <path d={iPath} fill="none" stroke="#06b6d4" stroke-width="2.5" stroke-linecap="round" opacity="0.25" filter="url(#glow-c)" />
          <path d={iPath} fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>
  </div>
</section>
